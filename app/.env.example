# Template des variables d'environnement

# Clé API Notion — récupérer sur https://notion.so/my-integrations
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxx

# ID de la base de données Notion
# Visible dans l'URL : notion.so/workspace/[CET_ID]?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
```

**`app/.gitignore`** :
```
# Dépendances Node.js — générées par npm install, jamais commitées
node_modules/

# Build Next.js — généré automatiquement, jamais commité
.next/

# Variables d'environnement — contiennent des secrets
.env.local
.env
.env*.local

# Fichiers système macOS
.DS_Store